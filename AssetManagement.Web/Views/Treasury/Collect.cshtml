@model AssetManagement.Application.ViewModels.TreasuryViewModel
@{
    ViewData["Title"] = "Treasury Collection";
}
<div class="row justify-content-center">
<div class="col-md-7">
    <div class="card border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#1e3a5f;">
            <i class="bi bi-bank me-2"></i>تحصيل الخزينة – الخطوة الأخيرة
        </div>
        <div class="card-body">

            <div class="alert alert-success border-0 shadow-sm mb-4">
                <div class="fw-bold fs-5 text-success mb-2">
                    <i class="bi bi-check-circle-fill me-2"></i>التحصيل النهائي
                </div>
                <div class="row">
                    <div class="col-6">
                        <div class="small text-muted">العقار</div>
                        <div class="fw-semibold">@Model.AssetName</div>
                        <code class="small">@Model.AssetCode</code>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">الطرف / العقد</div>
                        <div class="fw-semibold">@Model.PartyName</div>
                        <span class="badge @(Model.ContractType=="Rent"?"bg-info":"bg-success")">
                            @Model.ContractType
                        </span>
                    </div>
                </div>
                <hr class="my-2"/>
                <div class="text-center">
                    <div class="small text-muted">المبلغ المستحق</div>
                    <div class="fs-3 fw-bold text-success">@Model.Amount.ToString("N0") EGP</div>
                </div>
            </div>

            <form asp-action="Collect" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AssetId"/>
                <input type="hidden" asp-for="AssetName"/>
                <input type="hidden" asp-for="AssetCode"/>
                <input type="hidden" asp-for="PartyName"/>
                <input type="hidden" asp-for="Amount"/>
                <input type="hidden" asp-for="ContractType"/>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">طريقة الدفع *</label>
                        <select asp-for="PaymentMethod" class="form-select" required>
                            <option value="">-- اختر --</option>
                            <option value="Cash">نقداً</option>
                            <option value="Bank Transfer">تحويل بنكي</option>
                            <option value="Check">شيك</option>
                            <option value="Online Payment">دفع إلكتروني</option>
                        </select>
                        <span asp-validation-for="PaymentMethod" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">رقم الإيصال</label>
                        <input asp-for="ReceiptNumber" class="form-control"
                               placeholder="رقم الإيصال / معرف المعاملة"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">تاريخ التحصيل</label>
                        <input asp-for="CollectionDate" type="date" class="form-control"/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">ملاحظات</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"
                                  placeholder="ملاحظات إضافية..."></textarea>
                    </div>
                </div>

                <div class="alert alert-warning mt-3 mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    This action will <strong>إكمال سير العمل</strong> and mark the asset as
                    @(Model.ContractType == "Rent" ? "Rented" : "Sold").
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn fw-bold flex-grow-1 text-white"
                            style="background:#1e3a5f;">
                        <i class="bi bi-check-circle me-2"></i>تأكيد التحصيل وإتمام الصفقة
                    </button>
                    <a asp-controller="Asset" asp-action="Details"
                       asp-route-id="@Model.AssetId"
                       class="btn btn-outline-secondary">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>