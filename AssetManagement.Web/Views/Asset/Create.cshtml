@model AssetManagement.Application.ViewModels.AssetFormViewModel
@{
    ViewData["Title"] = "إضافة أصل جديد";
}
<div class="row justify-content-center">
<div class="col-md-9">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-plus-circle me-2"></i>إضافة أصل جديد
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">المحافظة *</label>
                        <input asp-for="City" class="form-control"/>
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">الحي / القسم *</label>
                        <input asp-for="District" class="form-control"/>
                        <span asp-validation-for="District" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">اسم الأصل *</label>
                        <input asp-for="AssetName" class="form-control"/>
                        <span asp-validation-for="AssetName" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">وصف الأصل</label>
                        <textarea asp-for="AssetDescription" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">نوع العقار</label>
                        <input asp-for="PropertyType" class="form-control" placeholder="محلات / شقق / أرض ..."/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">سند الملكية</label>
                        <input asp-for="DeedType" class="form-control"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">مساحة الأرض م²</label>
                        <input asp-for="LandArea" type="number" step="0.01" class="form-control"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">مساحة المباني م²</label>
                        <input asp-for="BuildingArea" type="number" step="0.01" class="form-control"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">الشركة المالكة</label>
                        <input asp-for="OwnerCompany" class="form-control"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">الموقف</label>
                        <select asp-for="OccupancyStatus" class="form-select">
                            <option value="">— اختر —</option>
                            <option value="مستغل">مستغل</option>
                            <option value="مؤجر">مؤجر</option>
                            <option value="فراغ">فراغ</option>
                            <option value="غير مستغل">غير مستغل</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">ملاحظات</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">العروض السابقة</label>
                        <textarea asp-for="PreviousOffers" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary fw-bold flex-grow-1">
                        <i class="bi bi-check-lg me-2"></i>حفظ
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
