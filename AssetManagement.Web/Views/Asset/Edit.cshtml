@model AssetManagement.Application.ViewModels.AssetFormViewModel
@{
    ViewData["Title"] = "تعديل الأصل";
}
<div class="row justify-content-center">
<div class="col-md-9">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-pencil-square me-2"></i>تعديل الأصل
            @if (!string.IsNullOrEmpty(Model.AssetCode))
            {<code class="ms-2">@Model.AssetCode</code>}
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id"/>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">المحافظة (City) *</label>
                    <input asp-for="City" class="form-control"/>
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">الحي / القسم (District) *</label>
                    <input asp-for="District" class="form-control"/>
                    <span asp-validation-for="District" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">اسم الأصل (AssetName) *</label>
                    <input asp-for="AssetName" class="form-control"/>
                    <span asp-validation-for="AssetName" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">وصف الأصل</label>
                    <textarea asp-for="AssetDescription" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">نوع العقار (PropertyType)</label>
                    <input asp-for="PropertyType" class="form-control" placeholder="محلات / شقق / أرض ..."/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">سند الملكية (DeedType)</label>
                    <input asp-for="DeedType" class="form-control"/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">مساحة الأرض (LandArea) م²</label>
                    <input asp-for="LandArea" type="number" step="0.01" class="form-control"/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">مساحة المباني (BuildingArea) م²</label>
                    <input asp-for="BuildingArea" type="number" step="0.01" class="form-control"/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">ملك شركة (OwnerCompany)</label>
                    <input asp-for="OwnerCompany" class="form-control"/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">الموقف (OccupancyStatus)</label>
                    <select asp-for="OccupancyStatus" class="form-select">
                        <option value="">— اختر —</option>
                        <option value="مستعل">مستعل</option>
                        <option value="مؤجر">مؤجر</option>
                        <option value="فراع">فراع</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">ملاحظات (Notes)</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">العروض السابقة (PreviousOffers)</label>
                    <textarea asp-for="PreviousOffers" class="form-control" rows="2"></textarea>
                </div>
            </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning fw-bold flex-grow-1">
                            <i class="bi bi-save me-2"></i>حفظ التعديل 
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">الغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>
