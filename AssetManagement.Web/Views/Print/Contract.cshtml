@{
    Layout = null;
    var asset    = (AssetManagement.Domain.Entities.Asset)ViewBag.Asset;
    var contract = (AssetManagement.Domain.Entities.Contract)ViewBag.Contract;
    bool isSale  = contract.ContractType == AssetManagement.Domain.Enums.ContractType.Sale;
    bool isComm  = !isSale && (asset.AssetName.Contains("محل") || asset.AssetName.Contains("مكتب") || asset.AssetName.Contains("تجار"));
    string today = DateTime.Now.ToString("yyyy/MM/dd");
    string area  = asset.Area.HasValue ? asset.Area.Value.ToString("N0") + " " + asset.AreaUnit : "-";
}
<!DOCTYPE html><html lang="ar" dir="rtl">
<head><meta charset="UTF-8"/>
<title>@contract.ContractNumber</title>
<style>
@@media print{@@page{margin:2cm}.no-print{display:none}}
body{font-family:'Traditional Arabic',Arial;font-size:14px;direction:rtl;margin:30px;color:#000}
.hdr{text-align:center;border-bottom:3px double #000;padding-bottom:12px;margin-bottom:18px}
.hdr h2{font-size:18px;font-weight:bold;margin:3px 0}
.ttl{text-align:center;font-size:20px;font-weight:bold;margin:18px 0;text-decoration:underline}
.box{border:1px solid #000;padding:10px;margin:12px 0}
.box table{width:100%}.box td{padding:5px;font-size:14px}
.box td:first-child{font-weight:bold;width:180px}
.bnd{font-weight:bold;font-size:14px;margin:12px 0 4px}
p.c{text-align:justify;line-height:2;margin:5px 0}
.sigs{margin-top:60px}.sigs table{width:100%}.sigs td{text-align:center;width:50%;padding:10px}
.sig-line{border-top:1px solid #000;margin-top:70px;padding-top:5px}
.btn{background:#1a56db;color:#fff;border:none;padding:10px 20px;border-radius:8px;font-size:14px;cursor:pointer;margin:5px}
</style></head><body>
<div class="no-print" style="margin-bottom:20px">
  <button class="btn" onclick="window.print()">طباعة</button>
  <button class="btn" style="background:#6c757d" onclick="window.history.back()">رجوع</button>
</div>
<div class="hdr">
  <h2>شركة بيت الخبرة للاستثمار الاقتصادي (تكنو إنفستمنت)</h2>
  <p>شركة مساهمة مصرية – منشأة وفقاً للقانون رقم 159 لسنة 1981</p>
  <p>رقم العقد: <strong>@contract.ContractNumber</strong> | تاريخ: <strong>@today</strong></p>
</div>
@if (isSale) {
<div class="ttl">عقد بيع نهائي وحدة سكنية</div>
<div class="box"><table>
<tr><td>البائع:</td><td>شركة بيت الخبرة للاستثمار الاقتصادي</td></tr>
<tr><td>المشتري:</td><td>@contract.PartyName</td></tr>
<tr><td>رقم الهوية:</td><td>@contract.PartyIdNumber</td></tr>
<tr><td>الهاتف:</td><td>@contract.PartyPhone</td></tr>
<tr><td>الوحدة:</td><td>@asset.AssetName - @asset.Location - @asset.City</td></tr>
<tr><td>المساحة:</td><td>@area</td></tr>
<tr><td>الثمن:</td><td><strong>@contract.Amount.ToString("N0") جنيه مصري</strong></td></tr>
</table></div>
<p class="c">إنه في يوم <strong>@today</strong> قد تم الاتفاق والتراضي بين: <strong>أولاً (بائع):</strong> شركة بيت الخبرة. <strong>ثانياً (مشترٍ):</strong> السيد/ة <strong>@contract.PartyName</strong> – هوية: <strong>@contract.PartyIdNumber</strong> – هاتف: <strong>@contract.PartyPhone</strong></p>
<div class="bnd">البند الأول (موضوع العقد)</div>
<p class="c">باع وتنازل الطرف الأول للطرف الثاني وحدة <strong>@asset.AssetName</strong> بـ <strong>@asset.Location - @asset.City</strong> مساحتها <strong>@area</strong>.</p>
<div class="bnd">البند الثاني (الثمن)</div>
<p class="c">الثمن الإجمالي <strong>@contract.Amount.ToString("N0") جنيه مصري</strong>. سدد الطرف الثاني كامل الثمن وأصبح العقد قابلاً للتسجيل.</p>
<div class="bnd">البند الثالث (المعاينة والتسليم)</div>
<p class="c">يُقر المشتري بمعاينة الوحدة المعاينة التامة وقبولها، ويتم التسليم بموجب محضر استلام.</p>
<div class="bnd">البند الرابع (مصاريف التسجيل)</div>
<p class="c">يتحمل المشتري جميع مصاريف التسجيل ورسوم الشهر العقاري وضريبة التصرفات العقارية.</p>
<div class="bnd">البند الخامس (الاختصاص القضائي)</div>
<p class="c">تختص محكمة شمال القاهرة الابتدائية بأي نزاع ينشأ عن هذا العقد.</p>
} else if (!isComm) {
<div class="ttl">عقد إيجار وحدة سكنية</div>
<p style="text-align:center;font-size:12px">وفقاً للقانون 4 لسنة 1996 والقانون 137 لسنة 2006</p>
<div class="box"><table>
<tr><td>المستأجر:</td><td>@contract.PartyName</td></tr>
<tr><td>رقم الهوية:</td><td>@contract.PartyIdNumber</td></tr>
<tr><td>الهاتف:</td><td>@contract.PartyPhone</td></tr>
<tr><td>الوحدة:</td><td>@asset.AssetName - @asset.Location - @asset.City</td></tr>
<tr><td>المساحة:</td><td>@area</td></tr>
<tr><td>الإيجار الشهري:</td><td><strong>@contract.Amount.ToString("N0") جنيه مصري</strong></td></tr>
<tr><td>مدة العقد:</td><td>من @contract.StartDate?.ToString("yyyy/MM/dd") إلى @contract.EndDate?.ToString("yyyy/MM/dd")</td></tr>
</table></div>
<p class="c">إنه في يوم <strong>@today</strong> تم تحرير هذا العقد بين: <strong>أولاً (مؤجر):</strong> شركة بيت الخبرة. <strong>ثانياً (مستأجر):</strong> <strong>@contract.PartyName</strong> – هوية: <strong>@contract.PartyIdNumber</strong></p>
<div class="bnd">البند الأول (موضوع العقد)</div>
<p class="c">أجّر الطرف الأول للطرف الثاني الوحدة السكنية <strong>@asset.AssetName</strong> بـ <strong>@asset.Location</strong> للسكن فقط.</p>
<div class="bnd">البند الثاني (القيمة الإيجارية)</div>
<p class="c">الإيجار الشهري <strong>@contract.Amount.ToString("N0") جنيه</strong>. السداد من 1 إلى 5 من كل شهر. غرامة تأخر 2.5% يومياً.</p>
<div class="bnd">البند الثالث (مدة العقد)</div>
<p class="c">من <strong>@contract.StartDate?.ToString("yyyy/MM/dd")</strong> حتى <strong>@contract.EndDate?.ToString("yyyy/MM/dd")</strong> غير قابلة للتجديد.</p>
<div class="bnd">البند الرابع (الإيجار من الباطن)</div>
<p class="c">لا يجوز للمستأجر تأجير الوحدة من الباطن أو التنازل عنها دون إذن كتابي.</p>
<div class="bnd">البند الخامس (الاختصاص القضائي)</div>
<p class="c">تختص محكمة شمال القاهرة بالفصل في أي نزاع.</p>
} else {
<div class="ttl">عقد إيجار وحدة تجارية</div>
<p style="text-align:center;font-size:12px">وفقاً للقانون 4 لسنة 1996 والقانون 137 لسنة 2006</p>
<div class="box"><table>
<tr><td>المستأجر:</td><td>@contract.PartyName</td></tr>
<tr><td>رقم الهوية:</td><td>@contract.PartyIdNumber</td></tr>
<tr><td>الهاتف:</td><td>@contract.PartyPhone</td></tr>
<tr><td>الوحدة التجارية:</td><td>@asset.AssetName - @asset.Location - @asset.City</td></tr>
<tr><td>المساحة:</td><td>@area</td></tr>
<tr><td>الإيجار الشهري:</td><td><strong>@contract.Amount.ToString("N0") جنيه مصري</strong></td></tr>
<tr><td>مدة العقد:</td><td>من @contract.StartDate?.ToString("yyyy/MM/dd") إلى @contract.EndDate?.ToString("yyyy/MM/dd")</td></tr>
</table></div>
<p class="c">إنه في يوم <strong>@today</strong> تحرر هذا العقد بين: <strong>أولاً (مؤجر):</strong> شركة بيت الخبرة. <strong>ثانياً (مستأجر):</strong> <strong>@contract.PartyName</strong> – هوية: <strong>@contract.PartyIdNumber</strong></p>
<div class="bnd">البند الأول (موضوع العقد)</div>
<p class="c">أجّر الطرف الأول للطرف الثاني الوحدة التجارية <strong>@asset.AssetName</strong> بـ <strong>@asset.Location</strong>. لا يجوز تغيير الاستعمال إلا بموافقة كتابية.</p>
<div class="bnd">البند الثاني (القيمة الإيجارية)</div>
<p class="c">الإيجار الشهري <strong>@contract.Amount.ToString("N0") جنيه</strong>. السداد من 15 إلى 19 من كل شهر. غرامة تأخر 2.5% يومياً.</p>
<div class="bnd">البند الثالث (مدة العقد)</div>
<p class="c">من <strong>@contract.StartDate?.ToString("yyyy/MM/dd")</strong> حتى <strong>@contract.EndDate?.ToString("yyyy/MM/dd")</strong> غير قابلة للتجديد.</p>
<div class="bnd">البند الرابع (الالتزامات)</div>
<p class="c">يلتزم المستأجر بأجهزة مكافحة الحريق والتراخيص اللازمة وعدم وضع لافتات خارج الأماكن المخصصة.</p>
<div class="bnd">البند الخامس (الاختصاص القضائي)</div>
<p class="c">تختص محكمة شمال القاهرة بالفصل في أي نزاع.</p>
}
<div class="sigs"><table><tr>
<td><strong>الطرف الأول</strong><div class="sig-line">شركة بيت الخبرة<br/>التوقيع: _______________</div></td>
<td><strong>الطرف الثاني</strong><div class="sig-line">@contract.PartyName<br/>التوقيع: _______________</div></td>
</tr></table></div>
<div style="text-align:center;margin-top:25px;font-size:12px;color:#888;border-top:1px solid #ccc;padding-top:8px">
  رقم العقد: @contract.ContractNumber | تاريخ: @today | @asset.AssetName
</div>
</body></html>
